// Workshop Management System - Prisma Schema
// Based on ERD diagram - All relations validated

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  SUPERADMIN
}

enum WorkOrderStatus {
  ANTRI
  PROSES
  SELESAI
}

enum ServiceCategory {
  SERVIS
  CUCI
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
}

enum PaymentStatus {
  PENDING
  LUNAS
}

enum EarningType {
  SALARY
  COMMISSION
}

enum InventoryLogType {
  IN
  OUT
}

enum ClosingStatus {
  OPEN
  CLOSED
}

// ============================================
// AUTH & USER MANAGEMENT
// ============================================

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@map("users")
}

// ============================================
// EMPLOYEE MANAGEMENT
// ============================================

model Employee {
  id        String   @id @default(uuid())
  name      String
  position  String   @default("Mekanik")
  email     String?
  phone     String?
  salary    Decimal  @default(0) @db.Decimal(12, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]
  earnings   EmployeeEarning[]

  @@map("employees")
}

// ============================================
// CUSTOMER & VEHICLE
// ============================================

model Customer {
  id        String   @id @default(uuid())
  name      String?
  phone     String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles Vehicle[]

  @@map("customers")
}

model Vehicle {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  plateNumber String   @map("plate_number")
  type        String?
  brand       String?
  model       String?
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@map("vehicles")
}

// ============================================
// SERVICES & COMMISSION
// ============================================

model Service {
  id        String          @id @default(uuid())
  name      String
  category  ServiceCategory
  price     Decimal         @db.Decimal(12, 2)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  workOrderServices WorkOrderService[]
  commission        ServiceCommission?

  @@map("services")
}

model ServiceCommission {
  id             String  @id @default(uuid())
  serviceId      String  @unique @map("service_id")
  commissionRate Decimal @map("commission_rate") @db.Decimal(5, 2)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_commissions")
}

// ============================================
// WORK ORDER (CORE SYSTEM)
// ============================================

model WorkOrder {
  id            String          @id @default(uuid())
  vehicleId     String          @map("vehicle_id")
  employeeId    String?         @map("employee_id")
  userId        String          @map("user_id")
  trackingToken String          @unique @map("tracking_token")
  status        WorkOrderStatus @default(ANTRI)
  serviceType   ServiceCategory @map("service_type")
  totalCost     Decimal         @default(0) @map("total_cost") @db.Decimal(12, 2)
  notes         String?
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  vehicle      Vehicle                @relation(fields: [vehicleId], references: [id])
  employee     Employee?              @relation(fields: [employeeId], references: [id])
  user         User                   @relation(fields: [userId], references: [id])
  services     WorkOrderService[]
  parts        WorkOrderPart[]
  transaction  Transaction?
  earnings     EmployeeEarning[]
  historyItems WorkOrderHistoryItem[]

  @@map("work_orders")
}

model WorkOrderService {
  id          String  @id @default(uuid())
  workOrderId String  @map("work_order_id")
  serviceId   String  @map("service_id")
  price       Decimal @db.Decimal(12, 2)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id])

  @@map("work_order_services")
}

model WorkOrderPart {
  id          String  @id @default(uuid())
  workOrderId String  @map("work_order_id")
  inventoryId String  @map("inventory_id")
  qty         Int
  price       Decimal @db.Decimal(12, 2)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@map("work_order_parts")
}

// ============================================
// TRANSACTION
// ============================================

model Transaction {
  id            String        @id @default(uuid())
  workOrderId   String        @unique @map("work_order_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@map("transactions")
}

// ============================================
// INVENTORY
// ============================================

model Inventory {
  id        String   @id @default(uuid())
  name      String
  category  String?
  qty       Int      @default(0)
  unit      String
  minStock  Int      @default(0) @map("min_stock")
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs  InventoryLog[]
  parts WorkOrderPart[]

  @@map("inventory")
}

model InventoryLog {
  id          String           @id @default(uuid())
  inventoryId String           @map("inventory_id")
  qty         Int
  type        InventoryLogType
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("inventory_logs")
}

// ============================================
// EXPENSE
// ============================================

model Expense {
  id          String   @id @default(uuid())
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("expenses")
}

// ============================================
// PAYROLL - EMPLOYEE EARNINGS
// ============================================

model EmployeeEarning {
  id          String      @id @default(uuid())
  employeeId  String      @map("employee_id")
  workOrderId String?     @map("work_order_id")
  earningType EarningType @map("earning_type")
  amount      Decimal     @db.Decimal(12, 2)
  month       Int
  year        Int
  createdAt   DateTime    @default(now()) @map("created_at")

  employee  Employee   @relation(fields: [employeeId], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("employee_earnings")
}

// ============================================
// FINANCIAL - MONTHLY CLOSING
// ============================================

model MonthlyClosing {
  id           String        @id @default(uuid())
  month        Int
  year         Int
  totalRevenue Decimal       @map("total_revenue") @db.Decimal(12, 2)
  totalExpense Decimal       @map("total_expense") @db.Decimal(12, 2)
  totalSalary  Decimal       @map("total_salary") @db.Decimal(12, 2)
  profit       Decimal       @db.Decimal(12, 2)
  status       ClosingStatus @default(OPEN)
  closedAt     DateTime?     @map("closed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([month, year])
  @@map("monthly_closings")
}

// ============================================
// WORK ORDER HISTORY (MANUAL ITEMS)
// ============================================

model WorkOrderHistoryItem {
  id          String @id @default(uuid())
  workOrderId String @map("work_order_id")

  title       String
  description String?
  price       Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("work_order_history_items")
}
